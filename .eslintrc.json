{
  "env": {
    "node": true,
    "es2023": true,
    "browser": true
  },
  "parserOptions": {
    "ecmaVersion": 2023,
    "sourceType": "commonjs"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "off",
    "prefer-const": "warn",
    "eqeqeq": ["error", "always"]
  },
  "ignorePatterns": ["node_modules/", "public/assets/vendor/", "uploads/", "dist/"]
}
