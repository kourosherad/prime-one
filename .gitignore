# Dependencies
node_modules/
.pnp
.pnp.js

# Environment
.env
.env.local
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime
*.pid
*.seed
*.pid.lock

# Uploads (user content, not committed)
uploads/*
!uploads/.gitkeep

# Build / cache
.cache/
dist/
build/
tmp/
.tmp/

# IMPORTANT: do NOT ignore the compiled Tailwind output that ships with the
# static frontend. The broad "dist/" rule above would otherwise exclude
# public/assets/dist/tailwind.css.
!public/assets/dist/
!public/assets/dist/**

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Coverage
coverage/
.nyc_output/

# Tailwind build artifacts
public/assets/css/tailwind.css

# GitHub Pages build output (regenerated by CI)
dist-pages/
